APP_NAME=Pulseboard Analytics
ENVIRONMENT=local
FRONTEND_ORIGIN=http://localhost:3000
DATABASE_URL=postgresql+asyncpg://analytics:analytics@postgres:5432/analytics
TEST_DATABASE_URL=postgresql+asyncpg://analytics:analytics@postgres:5432/analytics_test
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
ACCESS_TOKEN_SECRET=replace-with-a-long-random-secret
REFRESH_TOKEN_SECRET=replace-with-a-different-long-random-secret
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=14
COOKIE_SECURE=false
REFRESH_COOKIE_PATH=/
INGESTION_RATE_LIMIT_PER_MINUTE=1200
PUBLIC_SHARE_BASE_URL=http://localhost:3000
API_INTERNAL_URL=http://api:8000/api/v1
NEXT_PUBLIC_API_URL=/api/backend
