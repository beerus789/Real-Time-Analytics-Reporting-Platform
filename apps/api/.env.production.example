APP_NAME=Pulseboard Analytics
ENVIRONMENT=production
FRONTEND_ORIGIN=https://your-vercel-app.vercel.app
PUBLIC_SHARE_BASE_URL=https://your-vercel-app.vercel.app

# Neon: use the normal Postgres connection string from Neon.
# The app accepts postgresql:// and normalizes it to SQLAlchemy's asyncpg driver.
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require

# Upstash Redis for Celery/rate limiting.
# Upstash's Celery docs use rediss with ssl_cert_reqs=required.
REDIS_URL=rediss://:PASSWORD@HOST.upstash.io:PORT?ssl_cert_reqs=required
CELERY_BROKER_URL=rediss://:PASSWORD@HOST.upstash.io:PORT?ssl_cert_reqs=required
CELERY_RESULT_BACKEND=rediss://:PASSWORD@HOST.upstash.io:PORT?ssl_cert_reqs=required

ACCESS_TOKEN_SECRET=replace-with-a-long-random-secret
REFRESH_TOKEN_SECRET=replace-with-a-different-long-random-secret
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=14
COOKIE_SECURE=true
REFRESH_COOKIE_PATH=/
INGESTION_RATE_LIMIT_PER_MINUTE=1200
